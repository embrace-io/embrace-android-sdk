{%- set class_name = ctx.group_id | replace(".", "_") | pascal_case ~ "Attributes" -%}
package io.embrace.android.embracesdk.semconv

/**
 * Autogenerated Embrace semantic conventions for '{{ ctx.group_id }}'.
 *
 * {{ ctx.brief }}
 *
 * DO NOT EDIT - AUTOGENERATED FILE
 */
@Suppress("unused")
object {{ class_name }} {
{%- for attribute in ctx.attributes %}

    /**
     * {{ attribute.brief }}
     */
    {%- if ctx.stability == "development" %}
    @ExperimentalSemconv
    {%- endif %}
    const val {{ attribute.name | screaming_snake_case }}: String = "{{ attribute.name }}"
    {%- if attribute.type is mapping and attribute.type.members is defined %}

    object {{ attribute.name | replace(".", "_") | pascal_case }}Values {
        {%- for member in attribute.type.members %}

        /**
         * {{ member.brief }}
         */
        {%- if ctx.stability == "development" %}
        @ExperimentalSemconv
        {%- endif %}
        const val {{ member.id | screaming_snake_case }}: String = "{{ member.value }}"
        {%- endfor %}
    }
    {%- endif %}
{%- endfor %}
}
