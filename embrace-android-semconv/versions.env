# External versions of Weaver and dependent semantic convention registries
# Version congruency validated by check.sh

WEAVER_VERSION=v0.24.2

# The core OpenTelemetry semantic conventions registry this one depends on. Must
# match the otel dependency tag in src/main/semconv/manifest.yaml
CORE_SEMCONV_VERSION=v1.43.0

# The shared Embrace semantic conventions registry this one federates on. Must match the
# embrace dependency tag in src/main/semconv/manifest.yaml
EMBRACE_SEMCONV_VERSION=v0.1.0
